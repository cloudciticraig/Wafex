# --- Database (provided automatically by Railway when you attach PostgreSQL) ---
DATABASE_URL=postgres://user:password@host:5432/wafex
# Set to "require" only when connecting through a proxy that needs SSL (e.g. proxy.rlwy.net)
# PGSSLMODE=require

# --- Microsoft Entra ID SSO (leave unset to run in open demo mode) ---
AZURE_TENANT_ID=your-tenant-guid
AZURE_CLIENT_ID=app-registration-client-id
AZURE_CLIENT_SECRET=app-registration-client-secret
# Public URL of the deployed app (used to build the OAuth redirect URI)
APP_BASE_URL=https://your-app.up.railway.app
# Long random string; keeps sessions valid across deploys
SESSION_SECRET=generate-a-long-random-string
# Set to "true" once app roles are assigned in Entra, to deny users with no role
# REQUIRE_ROLES=true

# Set by Railway automatically
# PORT=3000
